# =============================================================================
# Hetzner Kubernetes Cluster - Example Configuration
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
# =============================================================================

# -- Authentication (REQUIRED) ------------------------------------------------
# Create a token at: https://console.hetzner.cloud → Project → Security → API Tokens
hcloud_token = "YOUR_HCLOUD_API_TOKEN"

# -- Cluster Metadata ---------------------------------------------------------
cluster_name = "k8s"
environment  = "production"   # dev | staging | production

# -- Location ------------------------------------------------------------------
location     = "nbg1"         # nbg1 (Nuremberg), fsn1 (Falkenstein), hel1 (Helsinki)
network_zone = "eu-central"   # eu-central | us-east | us-west

# -- Network -------------------------------------------------------------------
network_cidr = "10.0.0.0/8"
subnet_cidr  = "10.0.0.0/16"

# -- Control Plane -------------------------------------------------------------
control_plane_count       = 3          # 1 for dev, 3 for HA production
control_plane_server_type = "cpx31"    # 4 vCPU, 8GB RAM, 160GB NVMe
control_plane_image       = "ubuntu-24.04"

# -- Workers -------------------------------------------------------------------
worker_count       = 3
worker_server_type = "cpx31"           # 4 vCPU, 8GB RAM, 160GB NVMe
worker_image       = "ubuntu-24.04"

# -- k3s Configuration --------------------------------------------------------
k3s_version = "v1.30.2+k3s1"
pod_cidr    = "10.42.0.0/16"
service_cidr = "10.43.0.0/16"
cluster_dns = "10.43.0.10"

# -- SSH Keys ------------------------------------------------------------------
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"

# -- Load Balancer -------------------------------------------------------------
lb_type = "lb11"               # lb11 (25 targets) | lb21 (75 targets)

# -- Labels --------------------------------------------------------------------
labels = {
  managed_by = "terraform"
  project    = "k8s-cluster"
}
