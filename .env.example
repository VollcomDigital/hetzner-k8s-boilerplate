# =============================================================================
# Environment Variables for Hetzner Kubernetes Boilerplate
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -- Required ------------------------------------------------------------------

# Hetzner Cloud API Token
HCLOUD_TOKEN=your-hetzner-cloud-api-token

# Email for Let's Encrypt certificates (required for cert-manager)
ACME_EMAIL=admin@example.com

# -- SSH -----------------------------------------------------------------------

SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519

# -- Kubeconfig ----------------------------------------------------------------

KUBECONFIG=./kubeconfig.yaml

# -- Monitoring ----------------------------------------------------------------

# Grafana admin password (auto-generated if empty)
GRAFANA_ADMIN_PASSWORD=

# -- DNS (optional, for external-dns) -----------------------------------------

# Provider: cloudflare or hetzner
DNS_PROVIDER=cloudflare

# Cloudflare API token (required if DNS_PROVIDER=cloudflare)
CF_API_TOKEN=

# Hetzner DNS API token (required if DNS_PROVIDER=hetzner, separate from HCLOUD_TOKEN)
HETZNER_DNS_TOKEN=

# -- Backup (optional, for Velero) ---------------------------------------------

# S3-compatible endpoint for Velero backups
# VELERO_S3_ENDPOINT=https://s3.example.com
# VELERO_S3_BUCKET=velero-backups
# VELERO_AWS_ACCESS_KEY=
# VELERO_AWS_SECRET_KEY=

# -- Hubble UI (optional) -----------------------------------------------------

# HUBBLE_USER=admin
# HUBBLE_PASSWORD=   # Auto-generated if empty
