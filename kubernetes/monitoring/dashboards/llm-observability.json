{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_TEMPO",
      "label": "Tempo",
      "description": "",
      "type": "datasource",
      "pluginId": "tempo",
      "pluginName": "Tempo"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "tempo",
      "name": "Tempo",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "LLM Observability Dashboard — token usage, latency, error rate, and cost estimation per model. Powered by OpenTelemetry GenAI semantic conventions (gen_ai.*) via OpenLLMetry or OTel GenAI SDK.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "Token Consumption Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short",
          "displayName": "Total Tokens (24h)"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 201,
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "title": "Total Tokens (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(traces_spanmetrics_calls_total{gen_ai_system=~\"$llm_provider\"}[24h]))",
          "legendFormat": "Calls",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 202,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "title": "P99 LLM Latency",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(traces_spanmetrics_duration_milliseconds_bucket{gen_ai_system=~\"$llm_provider\",gen_ai_request_model=~\"$model\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 203,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "title": "LLM Error Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(traces_spanmetrics_calls_total{gen_ai_system=~\"$llm_provider\",status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_spanmetrics_calls_total{gen_ai_system=~\"$llm_provider\"}[$__rate_interval]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 210,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "LLM API Call Rate by Model",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (gen_ai_request_model) (rate(traces_spanmetrics_calls_total{gen_ai_system=~\"$llm_provider\"}[$__rate_interval]))",
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 211,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "LLM Latency p50/p99 by Model",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (gen_ai_request_model, le) (rate(traces_spanmetrics_duration_milliseconds_bucket{gen_ai_system=~\"$llm_provider\"}[$__rate_interval])))",
          "legendFormat": "p50 {{gen_ai_request_model}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (gen_ai_request_model, le) (rate(traces_spanmetrics_duration_milliseconds_bucket{gen_ai_system=~\"$llm_provider\"}[$__rate_interval])))",
          "legendFormat": "p99 {{gen_ai_request_model}}",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 220,
      "title": "Cost Estimation",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Cost per 1M tokens at approximate public pricing. Update multipliers for your actual contract rates.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 221,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Estimated Cost / Hour by Model (approx.)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (gen_ai_request_model) (\n  # Input tokens: $3/1M for gpt-4o (adjust per model via recording rules)\n  rate(traces_spanmetrics_calls_total{gen_ai_system=\"openai\",gen_ai_operation_name=\"chat\"}[$__rate_interval])\n) * 3600",
          "legendFormat": "{{gen_ai_request_model}} (estimate)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "align": "auto",
            "displayMode": "color-background-solid"
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99_ms" }, "properties": [{ "id": "unit", "value": "ms" }] },
          { "matcher": { "id": "byName", "options": "error_rate" }, "properties": [{ "id": "unit", "value": "percentunit" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 222,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "call_rate" }]
      },
      "title": "LLM Model Summary Table",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (gen_ai_request_model, gen_ai_system) (rate(traces_spanmetrics_calls_total{gen_ai_system=~\"$llm_provider\"}[$__rate_interval]))",
          "legendFormat": "{{gen_ai_system}} / {{gen_ai_request_model}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 37,
  "tags": ["llm", "ai", "genai", "otel", "openllmetry"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(traces_spanmetrics_calls_total{gen_ai_system=~\".+\"}, gen_ai_system)",
        "hide": 0,
        "includeAll": true,
        "label": "LLM Provider",
        "multi": false,
        "name": "llm_provider",
        "query": {
          "query": "label_values(traces_spanmetrics_calls_total{gen_ai_system=~\".+\"}, gen_ai_system)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(traces_spanmetrics_calls_total{gen_ai_system=~\"$llm_provider\"}, gen_ai_request_model)",
        "hide": 0,
        "includeAll": true,
        "label": "Model",
        "multi": false,
        "name": "model",
        "query": {
          "query": "label_values(traces_spanmetrics_calls_total{gen_ai_system=~\"$llm_provider\"}, gen_ai_request_model)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "LLM Observability (OTel GenAI)",
  "uid": "llm-observability",
  "version": 1
}
