// =============================================================================
// Grafana Alloy Configuration
// Universal OTel-native collector replacing Promtail.
//
// Pipeline:
//   [Apps via OTLP]  ──► resource_detection ──► k8sattributes ──► batch
//   [Pod stdout/err] ──► kubernetes log discovery ──► process
//
//   batch ──► traces  ──► Tempo (gRPC OTLP)
//         ──► metrics ──► Prometheus (remote_write)
//         ──► logs    ──► Loki (push API)
//
// OpenTelemetry GenAI semantic conventions (gen_ai.*) are forwarded
// as first-class trace attributes to enable LLM observability in Grafana.
// =============================================================================

// -----------------------------------------------------------------------------
// OTLP Receiver — apps send traces/metrics/logs here via OpenTelemetry SDKs
// (including OpenLLMetry for LLM observability)
// -----------------------------------------------------------------------------
otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    metrics = [otelcol.processor.resourcedetection.default.input]
    logs    = [otelcol.processor.resourcedetection.default.input]
    traces  = [otelcol.processor.resourcedetection.default.input]
  }
}

// -----------------------------------------------------------------------------
// Resource Detection — enriches telemetry with host/OS metadata
// -----------------------------------------------------------------------------
otelcol.processor.resourcedetection "default" {
  detectors = ["env", "system"]

  system {
    hostname_sources = ["os"]
  }

  output {
    metrics = [otelcol.processor.k8sattributes.default.input]
    logs    = [otelcol.processor.k8sattributes.default.input]
    traces  = [otelcol.processor.k8sattributes.default.input]
  }
}

// -----------------------------------------------------------------------------
// Kubernetes Attributes — enriches spans/metrics/logs with k8s context
// (namespace, pod name, deployment name, node name)
// -----------------------------------------------------------------------------
otelcol.processor.k8sattributes "default" {
  auth_type  = "serviceAccount"
  passthrough = false

  // Associate telemetry with the originating pod by IP or connection source
  pod_association {
    source {
      from = "resource_attribute"
      name = "k8s.pod.ip"
    }
  }

  pod_association {
    source {
      from = "connection"
    }
  }

  extract {
    metadata = [
      "k8s.pod.name",
      "k8s.pod.uid",
      "k8s.deployment.name",
      "k8s.statefulset.name",
      "k8s.daemonset.name",
      "k8s.namespace.name",
      "k8s.node.name",
      "k8s.pod.start_time",
    ]

    labels {
      from      = "pod"
      key       = "app.kubernetes.io/name"
      tag_name  = "service.name"
    }

    labels {
      from      = "pod"
      key       = "app.kubernetes.io/version"
      tag_name  = "service.version"
    }
  }

  output {
    metrics = [otelcol.processor.batch.default.input]
    logs    = [otelcol.processor.batch.default.input]
    traces  = [otelcol.processor.batch.default.input]
  }
}

// -----------------------------------------------------------------------------
// Batch Processor — buffers telemetry for efficient network I/O
// -----------------------------------------------------------------------------
otelcol.processor.batch "default" {
  send_batch_size     = 8192
  send_batch_max_size = 16384
  timeout             = "2s"

  output {
    // Traces → Tempo
    traces  = [otelcol.exporter.otlp.tempo.input]
    // Metrics → Prometheus remote_write
    metrics = [otelcol.exporter.prometheus.default.input]
    // OTel logs → Loki
    logs    = [otelcol.exporter.loki.default.input]
  }
}

// -----------------------------------------------------------------------------
// Traces → Tempo Distributor (gRPC OTLP)
// -----------------------------------------------------------------------------
otelcol.exporter.otlp "tempo" {
  client {
    endpoint = env("TEMPO_OTLP_ENDPOINT")
    tls {
      insecure = true
    }
  }
}

// -----------------------------------------------------------------------------
// OTel Metrics → Prometheus (via remote_write receiver)
// Carries application-level metrics including gen_ai.* token counts
// -----------------------------------------------------------------------------
otelcol.exporter.prometheus "default" {
  forward_to          = [prometheus.remote_write.default.receiver]
  add_metric_suffixes = false
}

prometheus.remote_write "default" {
  endpoint {
    url = env("PROMETHEUS_REMOTE_WRITE_URL")
  }
}

// -----------------------------------------------------------------------------
// OTel Logs → Loki
// -----------------------------------------------------------------------------
otelcol.exporter.loki "default" {
  forward_to = [loki.write.default.receiver]
}

// -----------------------------------------------------------------------------
// Kubernetes Pod Log Collection (replaces Promtail DaemonSet)
// Reads container log files from /var/log/pods on the host node.
// -----------------------------------------------------------------------------
discovery.kubernetes "pods" {
  role = "pod"
}

discovery.relabel "pod_logs" {
  targets = discovery.kubernetes.pods.targets

  // Drop pods in terminal states — their logs are complete
  rule {
    source_labels = ["__meta_kubernetes_pod_phase"]
    regex         = "Pending|Succeeded|Failed|Completed"
    action        = "drop"
  }

  // Build the __path__ pointing to the CRI log file on disk
  rule {
    source_labels = ["__meta_kubernetes_pod_uid", "__meta_kubernetes_pod_container_name"]
    separator     = "/"
    replacement   = "/var/log/pods/*$1/*.log"
    target_label  = "__path__"
  }

  rule {
    source_labels = ["__meta_kubernetes_namespace"]
    target_label  = "namespace"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_name"]
    target_label  = "pod"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_container_name"]
    target_label  = "container"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_node_name"]
    target_label  = "node"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_label_app_kubernetes_io_name"]
    regex         = "(.+)"
    replacement   = "$1"
    target_label  = "app"
  }

  // Propagate cluster-level labels for multi-cluster Grafana views
  rule {
    replacement  = "hetzner"
    target_label = "cluster"
  }
}

local.file_match "pod_logs" {
  path_targets = discovery.relabel.pod_logs.output
  sync_period  = "5s"
}

loki.source.file "pod_logs" {
  targets    = local.file_match.pod_logs.targets
  forward_to = [loki.process.pod_logs.receiver]
}

loki.process "pod_logs" {
  // Parse CRI (containerd/crio) log format: timestamp stream flags message
  stage.cri {}

  // Join multi-line stack traces (Java, Python, Go) that start on subsequent lines
  stage.multiline {
    firstline     = "^\\d{4}-\\d{2}-\\d{2}"
    max_wait_time = "3s"
  }

  // Drop the raw filename label — namespace/pod/container is sufficient
  stage.label_drop {
    values = ["filename"]
  }

  forward_to = [loki.write.default.receiver]
}

// -----------------------------------------------------------------------------
// Loki Write — ship logs to Loki push API
// -----------------------------------------------------------------------------
loki.write "default" {
  endpoint {
    url = env("LOKI_PUSH_URL")
  }
}

// -----------------------------------------------------------------------------
// Alloy self-metrics — expose own Prometheus metrics for the ServiceMonitor
// -----------------------------------------------------------------------------
prometheus.exporter.self "alloy" {}

prometheus.scrape "alloy_self" {
  targets    = prometheus.exporter.self.alloy.targets
  forward_to = [prometheus.remote_write.default.receiver]
  job_name   = "alloy"
}
